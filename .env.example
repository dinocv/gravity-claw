# Gravity Claw — Environment Variables
# Copy this to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenRouter API Key (from openrouter.ai/keys)
OPENROUTER_API_KEY=

# Comma-separated Telegram user IDs allowed to interact with the bot
# Find your ID by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Model to use via OpenRouter (optional, default: google/gemini-2.0-flash-001)
CLAUDE_MODEL=

# Preferred LLM providers (comma-separated): openrouter,ollama,anthropic,google,deepseek,groq
PREFERRED_PROVIDERS=

# Max agentic loop iterations (optional, default: 10)
MAX_ITERATIONS=

# Thinking level: off, low, medium, high
THINKING_LEVEL=

# Groq (for Whisper transcription)
GROQ_API_KEY=
GROQ_MODEL=

# ElevenLabs (for Voice output)
ELEVENLABS_API_KEY=

# Ollama (local LLM - free!)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic (optional direct)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini (optional direct)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash-001

# DeepSeek (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Web Search (Tavily - AI-powered search for agents, recommended)
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Firecrawl (Web scraping)
FIRECRAWL_API_KEY=

# SerpAPI (alternative)
SERPAPI_KEY=

# Pinecone Semantic Memory (Tier 3)
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_HOST=

# Local SQLite (Tier 1 & 2)
DB_PATH=memory.db

# Supabase (Optional fallback)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Security
AIR_GAPPED=false
ALLOWED_COMMANDS=ls,cat,grep,echo
ALLOWED_PATHS=.,/home

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC

# AgentMail (temporary email for signups)
AGENTMAIL_API_KEY=

